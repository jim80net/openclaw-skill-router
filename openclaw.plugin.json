{
  "id": "skill-router",
  "name": "Skill Router",
  "description": "Vector-based skill router that injects relevant skills per-turn using embedding similarity search with graduated disclosure",
  "version": "0.3.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": { "type": "boolean", "default": false },
      "topK": { "type": "number", "default": 3, "minimum": 1, "maximum": 10 },
      "threshold": { "type": "number", "default": 0.55, "minimum": 0.0, "maximum": 1.0 },
      "embeddingModel": { "type": "string", "default": "Xenova/all-MiniLM-L6-v2" },
      "embeddingBackend": {
        "type": "string",
        "enum": ["openai", "local"],
        "default": "local",
        "description": "Embedding backend: 'openai' (requires OPENAI_API_KEY) or 'local' (ONNX via @huggingface/transformers)"
      },
      "maxInjectedChars": { "type": "number", "default": 8000 },
      "cacheTimeMs": { "type": "number", "default": 300000 },
      "skillDirs": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Additional skill directories to index (workspace skills/ is always included)"
      },
      "types": {
        "type": "array",
        "items": {
          "type": "string",
          "enum": ["skill", "memory", "rule", "workflow", "tool-guidance", "session-learning"]
        },
        "default": ["skill", "memory", "workflow", "session-learning", "rule"],
        "description": "Knowledge types to include in routing"
      }
    }
  },
  "uiHints": {
    "enabled": { "label": "Enable skill router" },
    "topK": { "label": "Max skills to inject per turn" },
    "threshold": { "label": "Minimum similarity score (0-1)" },
    "embeddingModel": { "label": "Embedding model" },
    "embeddingBackend": { "label": "Embedding backend (openai or local)" },
    "maxInjectedChars": { "label": "Max characters to inject" },
    "types": { "label": "Knowledge types to route" }
  }
}
