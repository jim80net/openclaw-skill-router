{
  "id": "skill-router",
  "name": "Skill Router",
  "description": "Vector-based skill router that injects relevant skills per-turn using embedding similarity search",
  "version": "0.1.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": { "type": "boolean", "default": false },
      "topK": { "type": "number", "default": 3, "minimum": 1, "maximum": 10 },
      "threshold": { "type": "number", "default": 0.65, "minimum": 0.0, "maximum": 1.0 },
      "embeddingModel": { "type": "string", "default": "text-embedding-3-small" },
      "maxInjectedChars": { "type": "number", "default": 8000 },
      "cacheTimeMs": { "type": "number", "default": 300000 },
      "skillDirs": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Additional skill directories to index (workspace skills/ is always included)"
      },
      "syntheticQueryCount": { "type": "number", "default": 5, "minimum": 1, "maximum": 20 },
      "queryModel": { "type": "string", "default": "gpt-4.1-nano" }
    }
  },
  "uiHints": {
    "enabled": { "label": "Enable skill router" },
    "topK": { "label": "Max skills to inject per turn" },
    "threshold": { "label": "Minimum similarity score (0-1)" },
    "embeddingModel": { "label": "Embedding model" },
    "maxInjectedChars": { "label": "Max characters to inject" },
    "syntheticQueryCount": { "label": "Synthetic queries per skill" },
    "queryModel": { "label": "Query generation model" }
  }
}
